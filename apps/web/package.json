{
  "name": "@repo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build --webpack",
    "start": "next start --port 3000",
    "lint": "eslint .",
    "check-types": "next typegen && tsc --noEmit",
    "db:push": "prisma db push",
    "db:reset": "prisma db push --accept-data-loss && node --import tsx prisma/seed.ts",
    "seed": "node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.41.1",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "file:../../packages/eslint-config",
    "@repo/typescript-config": "file:../../packages/typescript-config",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "node --import tsx prisma/seed.ts"
  }
}
