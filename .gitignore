# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
.next/
apps/*/.next/
/out/

# production
/build
dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
apps/*/.env.local


# vercel
.vercel

# turbo
.turbo

# typescript
*.tsbuildinfo
next-env.d.ts

/storage/submissions/**
/storage/testdata/**

# local sqlite files
*.db
*.db-shm
*.db-wal

# keep one starter DB for easy setup
!apps/web/prisma/dev.db
docs

# Python bytecode
__pycache__/
*.pyc
*.pyo
